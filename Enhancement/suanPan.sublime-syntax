%YAML 1.2
---
file_extensions:
- supan
- sp
name: suanPan
scope: source.sp
contexts:
  main:
  - include: comments
  - include: demo
  - include: global
  - include: variables
  comments:
  - match: '!.*$'
    scope: comment
  - match: ^#.*$
    scope: comment
  demo:
  - match: ^comment$
    scope: comment
  - match: ^comment\.block$
    scope: comment.block
  - match: ^comment\.block\.documentation$
    scope: comment.block.documentation
  - match: ^comment\.line$
    scope: comment.line
  - match: ^comment\.line\.double-dash$
    scope: comment.line.double-dash
  - match: ^comment\.line\.double-slash$
    scope: comment.line.double-slash
  - match: ^comment\.line\.number-sign$
    scope: comment.line.number-sign
