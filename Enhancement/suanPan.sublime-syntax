    push:
    - match: $
      pop: true
    - match: \d+
      scope: variable
    captures:
      1: entity.name.tag
      2: entity.name.type
      3: variable
      4: support.type
  - match: (?i)^(?:(load)\s+)?(acceleration|bodyforce|cload|dispload|disp|displacement|groupbodyforce|groupcload|groupdisp|groupdisplacement|groupdispload|lineudl2d|lineudl3d|referenceload|refload|refforce|supportacceleration|supportdisplacement|supportvelocity|\$\S+)\s+(\d+)\s+(\d+)\s+(\S+)\s+(\S+)\b
