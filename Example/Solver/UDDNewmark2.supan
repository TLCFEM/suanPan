# A TEST MODEL FOR UNIFORM/UNIVERSAL DAMPING MODEL

node 1 0 0
node 2 1 0

material Bilinear1D 1 100 1 .05 1. 1E-2

element T2D2 1 1 2 1 1
element Mass 2 2 100 1

fix 1 1 1
fix 2 2 1 2

hdf5recorder 1 Node U1 2
hdf5recorder 2 Node RF1 2

step dynamic 1 1
set ini_step_size .1
set fixed_step_size 1

displacement 1 0 .02 1 2

integrator UDDNewmark 1 .25 .5 -2. 0 40. 0

converger RelIncreDisp 1 1E-10 3 1

analyze

peek integrator 1

peek node 2

reset
clear
exit