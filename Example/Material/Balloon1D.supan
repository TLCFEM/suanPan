node 1 0 0
node 2 1 0

material Balloon1D 1 \
2E5 5E3 1E-1 10 2 \
200 2E4 0 0 \ ! hf
0 0 0 0 \ ! ha
0 0 20 1 \ ! hb
200 2E4 0 0 \ ! hd
5E2 1. \ ! alpha
1E1 1. \ ! beta
5E2 0 ! d

element T2D2 1 1 2 1 1

fix2 1 1 1
fix2 2 2 1 2

amplitude Sine 2 1 1

disp 1 2 2e-3 1 2

step static 1 10
set fixed_step_size 1
set ini_step_size 1E-2
set symm_mat 0

converger RelIncreDisp 1 1E-10 10 1

analyze

peek element 1

reset
clear
exit